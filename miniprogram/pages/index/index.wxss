.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding-bottom: 160rpx;
}

.quote-section {
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  position: relative;
}

.quote-text {
  display: block;
  font-size: 36rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1.6;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.quote-decoration {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #e94560, transparent);
  margin: 40rpx auto 0;
}

.timeline-section {
  padding: 0 30rpx;
}

.timeline-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #e94560;
}

.dream-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.dream-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  transition: transform 0.3s ease;
  position: relative;
}

.dream-card:active {
  transform: scale(0.98);
}

.dream-card.processing {
  opacity: 0.9;
}

.processing-overlay, .failed-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8rpx);
  z-index: 10;
}

.processing-icon, .failed-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: pulse 2s ease-in-out infinite;
}

.processing-text, .failed-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.1);
  }
}

.dream-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.dream-content {
  padding: 24rpx;
}

.dream-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.dream-summary {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dream-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.dream-status {
  font-size: 24rpx;
  color: #ffd700;
  margin-top: 8rpx;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
}

.add-button {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 600rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 32rpx rgba(233, 69, 96, 0.4);
  z-index: 100;
}

.add-icon {
  font-size: 48rpx;
  color: #ffffff;
  margin-right: 12rpx;
  font-weight: 300;
}

.add-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}
