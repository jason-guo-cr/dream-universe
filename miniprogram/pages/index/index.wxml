<view class="container">
  <view class="quote-section">
    <view class="quote-text">"No one care about you, but the universe does, and that says a lot."</view>
    <view class="quote-decoration"></view>
  </view>

  <view class="timeline-section">
    <view class="timeline-title">梦境时间线</view>
    
    <view class="dream-list" wx:if="{{dreamList.length > 0}}">
      <view 
        class="dream-card" 
        wx:for="{{dreamList}}" 
        wx:key="_id"
        bindtap="onDreamTap"
        bindlongpress="onLongPressDream"
        data-index="{{index}}"
      >
        <image 
          class="dream-image" 
          src="{{item.imageUrl || '../../images/default-goods-image.png'}}" 
          mode="aspectFill"
        ></image>
        <view class="dream-content">
          <view class="dream-title">{{item.title}}</view>
          <view class="dream-summary">{{item.summary}}</view>
          <view class="dream-time">{{item.createTime}}</view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <image class="empty-icon" src="../../images/avatar.png" mode="aspectFit"></image>
      <text class="empty-text">还没有梦境记录</text>
      <text class="empty-hint">点击下方按钮开始记录你的第一个梦境</text>
    </view>
  </view>

  <view class="add-button" bindtap="onAddDream">
    <text class="add-icon">+</text>
    <text class="add-text">记录梦境</text>
  </view>
</view>
